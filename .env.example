# .env.example

# Backend Variables
# Port for the Express server to run on (default is 5000)
PORT=5000

# MongoDB connection string (replace with your MongoDB Atlas URI for production)
MONGODB_URI=mongodb://localhost:27017/finpilot

# JWT Secret for authentication (change this to a secure random string in production)
JWT_SECRET=your_jwt_secret_key_here


# Frontend Variables
# The URL where your backend API is hosted
NEXT_PUBLIC_API_URL=http://localhost:5000
